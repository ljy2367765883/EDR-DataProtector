<Application x:Class="DataProtectorAdmin.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="DpInkColor">#0E1724</Color>
            <Color x:Key="DpMutedColor">#66758A</Color>
            <Color x:Key="DpSubtleColor">#8793A4</Color>
            <Color x:Key="DpSurfaceColor">#FFFFFFFF</Color>
            <Color x:Key="DpShellColor">#FFF4F7FB</Color>
            <Color x:Key="DpLineColor">#FFE2E8F0</Color>
            <Color x:Key="DpLineStrongColor">#FFD0DAE7</Color>
            <Color x:Key="DpSuccessColor">#1B7F68</Color>
            <Color x:Key="DpSuccessSoftColor">#FFE8F6F1</Color>
            <Color x:Key="DpDangerColor">#C13D36</Color>
            <Color x:Key="DpDangerSoftColor">#FFFCEBE9</Color>
            <Color x:Key="DpWarningColor">#A96718</Color>
            <Color x:Key="DpWarningSoftColor">#FFFFF4DF</Color>
            <Color x:Key="DpCommandColor">#2454B4</Color>
            <Color x:Key="DpCommandSoftColor">#FFEAF0FF</Color>

            <SolidColorBrush x:Key="DpInkBrush" Color="{StaticResource DpInkColor}" />
            <SolidColorBrush x:Key="DpMutedBrush" Color="{StaticResource DpMutedColor}" />
            <SolidColorBrush x:Key="DpSubtleBrush" Color="{StaticResource DpSubtleColor}" />
            <SolidColorBrush x:Key="DpSurfaceBrush" Color="{StaticResource DpSurfaceColor}" />
            <SolidColorBrush x:Key="DpShellBrush" Color="{StaticResource DpShellColor}" />
            <SolidColorBrush x:Key="DpLineBrush" Color="{StaticResource DpLineColor}" />
            <SolidColorBrush x:Key="DpLineStrongBrush" Color="{StaticResource DpLineStrongColor}" />
            <SolidColorBrush x:Key="DpSuccessBrush" Color="{StaticResource DpSuccessColor}" />
            <SolidColorBrush x:Key="DpSuccessSoftBrush" Color="{StaticResource DpSuccessSoftColor}" />
            <SolidColorBrush x:Key="DpDangerBrush" Color="{StaticResource DpDangerColor}" />
            <SolidColorBrush x:Key="DpDangerSoftBrush" Color="{StaticResource DpDangerSoftColor}" />
            <SolidColorBrush x:Key="DpWarningBrush" Color="{StaticResource DpWarningColor}" />
            <SolidColorBrush x:Key="DpWarningSoftBrush" Color="{StaticResource DpWarningSoftColor}" />
            <SolidColorBrush x:Key="DpCommandBrush" Color="{StaticResource DpCommandColor}" />
            <SolidColorBrush x:Key="DpCommandSoftBrush" Color="{StaticResource DpCommandSoftColor}" />

            <Style x:Key="DpPanelStyle" TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{StaticResource DpSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DpLineBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="18" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="DpTitleStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style x:Key="DpSectionTitleStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="DpCaptionStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource DpMutedBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="LineHeight" Value="18" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="DpMetricValueStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="DpNavButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Height" Value="42" />
                <Setter Property="Padding" Value="13,0" />
                <Setter Property="Margin" Value="0,0,0,6" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
            </Style>

            <Style x:Key="DpIconButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Width" Value="34" />
                <Setter Property="Height" Value="34" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="MinWidth" Value="34" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
