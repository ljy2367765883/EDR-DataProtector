<Application x:Class="DataProtectorAgentClient.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="DpInkColor">#F5F1FF</Color>
            <Color x:Key="DpMutedColor">#B9AED4</Color>
            <Color x:Key="DpSubtleColor">#8E82A8</Color>
            <Color x:Key="DpShellColor">#E6130A24</Color>
            <Color x:Key="DpSurfaceColor">#6630204E</Color>
            <Color x:Key="DpLineColor">#38FFFFFF</Color>
            <Color x:Key="DpSideGlassColor">#57150D2C</Color>
            <Color x:Key="DpGlassStrongColor">#78372757</Color>
            <Color x:Key="DpTableHeaderColor">#6639285D</Color>
            <Color x:Key="DpTableRowColor">#40271843</Color>
            <Color x:Key="DpTableAltRowColor">#4D21153A</Color>
            <Color x:Key="DpTableHoverColor">#66483578</Color>
            <Color x:Key="DpTableSelectedColor">#8A6D4DCE</Color>
            <Color x:Key="DpSuccessColor">#65E6B2</Color>
            <Color x:Key="DpSuccessSoftColor">#3349C695</Color>
            <Color x:Key="DpDangerColor">#FF7F9C</Color>
            <Color x:Key="DpDangerSoftColor">#3DDC5D83</Color>
            <Color x:Key="DpWarningColor">#FFD37A</Color>
            <Color x:Key="DpWarningSoftColor">#3BD0923B</Color>
            <Color x:Key="DpCommandColor">#A98BFF</Color>
            <Color x:Key="DpCommandSoftColor">#456D4DCE</Color>
            <Color x:Key="DpTealColor">#5BE6FF</Color>
            <Color x:Key="DpTealSoftColor">#3331BFD0</Color>

            <SolidColorBrush x:Key="DpInkBrush" Color="{StaticResource DpInkColor}" />
            <SolidColorBrush x:Key="DpMutedBrush" Color="{StaticResource DpMutedColor}" />
            <SolidColorBrush x:Key="DpSubtleBrush" Color="{StaticResource DpSubtleColor}" />
            <SolidColorBrush x:Key="DpShellBrush" Color="{StaticResource DpShellColor}" />
            <SolidColorBrush x:Key="DpSurfaceBrush" Color="{StaticResource DpSurfaceColor}" />
            <SolidColorBrush x:Key="DpLineBrush" Color="{StaticResource DpLineColor}" />
            <SolidColorBrush x:Key="DpSideGlassBrush" Color="{StaticResource DpSideGlassColor}" />
            <SolidColorBrush x:Key="DpGlassStrongBrush" Color="{StaticResource DpGlassStrongColor}" />
            <SolidColorBrush x:Key="DpTableHeaderBrush" Color="{StaticResource DpTableHeaderColor}" />
            <SolidColorBrush x:Key="DpTableRowBrush" Color="{StaticResource DpTableRowColor}" />
            <SolidColorBrush x:Key="DpTableAltRowBrush" Color="{StaticResource DpTableAltRowColor}" />
            <SolidColorBrush x:Key="DpTableHoverBrush" Color="{StaticResource DpTableHoverColor}" />
            <SolidColorBrush x:Key="DpTableSelectedBrush" Color="{StaticResource DpTableSelectedColor}" />
            <SolidColorBrush x:Key="DpSuccessBrush" Color="{StaticResource DpSuccessColor}" />
            <SolidColorBrush x:Key="DpSuccessSoftBrush" Color="{StaticResource DpSuccessSoftColor}" />
            <SolidColorBrush x:Key="DpDangerBrush" Color="{StaticResource DpDangerColor}" />
            <SolidColorBrush x:Key="DpDangerSoftBrush" Color="{StaticResource DpDangerSoftColor}" />
            <SolidColorBrush x:Key="DpWarningBrush" Color="{StaticResource DpWarningColor}" />
            <SolidColorBrush x:Key="DpWarningSoftBrush" Color="{StaticResource DpWarningSoftColor}" />
            <SolidColorBrush x:Key="DpCommandBrush" Color="{StaticResource DpCommandColor}" />
            <SolidColorBrush x:Key="DpCommandSoftBrush" Color="{StaticResource DpCommandSoftColor}" />
            <SolidColorBrush x:Key="DpTealBrush" Color="{StaticResource DpTealColor}" />
            <SolidColorBrush x:Key="DpTealSoftBrush" Color="{StaticResource DpTealSoftColor}" />

            <LinearGradientBrush x:Key="DpShellGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F00E071D" Offset="0" />
                <GradientStop Color="#EA211038" Offset="0.42" />
                <GradientStop Color="#F10B152D" Offset="1" />
            </LinearGradientBrush>

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
                <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
            </Style>

            <Style x:Key="DpPanelStyle" TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{StaticResource DpSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DpLineBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="18" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#7A04020C"
                                          BlurRadius="26"
                                          ShadowDepth="1"
                                          Opacity="0.38" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DpCaptionStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="Foreground" Value="{StaticResource DpMutedBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="LineHeight" Value="18" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style x:Key="DpSectionTitleStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style x:Key="DpMetricValueStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="FontSize" Value="30" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style x:Key="DpNavButtonStyle" TargetType="{x:Type ui:Button}">
                <Setter Property="Height" Value="42" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="Margin" Value="0,0,0,6" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="Background" Value="#29362559" />
                <Setter Property="BorderBrush" Value="#22FFFFFF" />
                <Setter Property="Appearance" Value="Transparent" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="DpIconButtonStyle" TargetType="{x:Type ui:Button}">
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="MinWidth" Value="36" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="Background" Value="{StaticResource DpGlassStrongBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DpLineBrush}" />
                <Setter Property="Appearance" Value="Transparent" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="DpDataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
                <Setter Property="Background" Value="{StaticResource DpTableHeaderBrush}" />
                <Setter Property="Foreground" Value="{StaticResource DpMutedBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DpLineBrush}" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="DpDataGridRowStyle" TargetType="{x:Type DataGridRow}">
                <Setter Property="Background" Value="{StaticResource DpTableRowBrush}" />
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DpLineBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="MinHeight" Value="50" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Style.Triggers>
                    <Trigger Property="AlternationIndex" Value="1">
                        <Setter Property="Background" Value="{StaticResource DpTableAltRowBrush}" />
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource DpTableHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource DpTableSelectedBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DpDataGridCellStyle" TargetType="{x:Type DataGridCell}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DpLineBrush}" />
                <Setter Property="BorderThickness" Value="0,0,1,0" />
                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DpDataGridTextStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextTrimming" Value="None" />
                <Setter Property="TextWrapping" Value="WrapWithOverflow" />
                <Setter Property="LineHeight" Value="19" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
            </Style>

            <Style x:Key="DpDataGridStyle" TargetType="{x:Type DataGrid}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DpLineBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="GridLinesVisibility" Value="None" />
                <Setter Property="HeadersVisibility" Value="Column" />
                <Setter Property="HorizontalGridLinesBrush" Value="Transparent" />
                <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
                <Setter Property="RowBackground" Value="{StaticResource DpTableRowBrush}" />
                <Setter Property="AlternatingRowBackground" Value="{StaticResource DpTableAltRowBrush}" />
                <Setter Property="AlternationCount" Value="2" />
                <Setter Property="MinRowHeight" Value="50" />
                <Setter Property="ColumnHeaderHeight" Value="40" />
                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="CanUserResizeColumns" Value="True" />
                <Setter Property="CanUserSortColumns" Value="True" />
                <Setter Property="ColumnHeaderStyle" Value="{StaticResource DpDataGridHeaderStyle}" />
                <Setter Property="RowStyle" Value="{StaticResource DpDataGridRowStyle}" />
                <Setter Property="CellStyle" Value="{StaticResource DpDataGridCellStyle}" />
                <Setter Property="CanUserAddRows" Value="False" />
                <Setter Property="CanUserDeleteRows" Value="False" />
                <Setter Property="IsReadOnly" Value="True" />
                <Setter Property="AutoGenerateColumns" Value="False" />
            </Style>

            <Style TargetType="{x:Type ui:InfoBar}">
                <Setter Property="Background" Value="{StaticResource DpGlassStrongBrush}" />
                <Setter Property="Foreground" Value="{StaticResource DpInkBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DpLineBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
